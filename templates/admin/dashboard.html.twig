{# templates/admin/dashboard.html.twig #}
{% extends 'admin/layout.html.twig' %}
{% import 'components/buttons.html.twig' as btn %}

{% block title %}Dashboard - SGR-Turnos{% endblock %}

{% block body %}
    <div class="max-w-7xl mx-auto space-y-12">
        {# Encabezado de página #}
        <div class="pl-6">
            <h2 class="text-4xl font-bold font-headline text-on-surface tracking-tight">Panel Principal</h2>
            <p class="text-lg text-on-surface-variant mt-2 font-medium">Visión general del estado operativo</p>
        </div>

        {# Grid Bento #}
        <div class="grid grid-cols-1 md:grid-cols-12 gap-8">
            {# 1. Resumen del Día #}
            <div
                class="col-span-12 md:col-span-4 bg-surface-container-lowest rounded-xl p-8 sunken-shadow flex flex-col justify-between relative overflow-hidden group">
                <div
                    class="absolute -right-6 -top-6 w-32 h-32 bg-primary/5 rounded-full blur-2xl group-hover:bg-primary/10 transition-colors duration-500"></div>
                <div>
                    <p class="text-sm font-semibold text-on-surface-variant tracking-wider uppercase mb-1">Resumen del
                        Día</p>
                    <h3 class="text-3xl font-bold text-primary mt-2">{{ fecha|date('d F Y') }}</h3>
                </div>
                <div class="mt-8 flex items-center justify-between">
                    <div class="w-12 h-12 rounded-full bg-primary-fixed flex items-center justify-center">
                        <span class="material-symbols-outlined text-primary-fixed-variant"
                              style="font-variation-settings: 'FILL' 1;">calendar_month</span>
                    </div>
                    <p class="text-sm font-medium text-on-surface-variant text-right">
                        {{ diaSemana }}<br/>Semana {{ semana }}
                    </p>
                </div>
            </div>

            {# 2. Turnos Activos (Pendientes hoy) #}
            <div
                class="col-span-12 md:col-span-4 bg-surface-container-lowest rounded-xl p-8 sunken-shadow flex flex-col justify-between">
                <div>
                    <div class="flex items-center justify-between mb-4">
                        <p class="text-sm font-semibold text-on-surface-variant tracking-wider uppercase">Turnos
                            Activos</p>
                        <span class="material-symbols-outlined text-outline-variant">trending_up</span>
                    </div>
                    <div class="flex items-baseline gap-2">
                        <h3 class="text-6xl font-bold text-on-surface tracking-tighter">{{ totalPendientesHoy }}</h3>
                        <span class="text-sm font-medium text-on-surface-variant">total</span>
                    </div>
                </div>
                <div class="mt-6 pt-4 border-t border-surface-variant/50 flex items-center gap-3">
                    <span class="w-2.5 h-2.5 rounded-full bg-secondary-container"></span>
                    <p class="text-sm font-medium text-on-surface">Pendientes para hoy</p>
                </div>
            </div>

            {# 3. Cajero Automático (Disponibilidad) #}
            <div
                class="col-span-12 md:col-span-4 bg-surface-container-lowest rounded-xl p-8 sunken-shadow flex flex-col justify-between">
                <div class="flex items-center justify-between mb-6">
                    <p class="text-sm font-semibold text-on-surface-variant tracking-wider uppercase">Cajero
                        Automático</p>
                    <span class="material-symbols-outlined text-outline-variant">atm</span>
                </div>
                <div class="space-y-4">
                    <div
                        class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-primary-fixed/50 text-on-primary-fixed-variant border border-primary-fixed">
                        <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
                        <span class="text-xs font-bold uppercase tracking-wide">Operativo</span>
                    </div>
                    <div>
                        <p class="text-sm text-on-surface-variant mb-1 font-medium">Turnos Disponibles</p>
                        <p class="text-3xl font-bold text-on-surface">
                            {{ totalTicketsDisponibles }}
                            <span class="text-base font-normal text-outline">/ total configurado</span>
                        </p>
                    </div>
                </div>
            </div>

            {# 4. Acciones Rápidas #}
            <div class="col-span-12 mt-4 bg-surface-container-low rounded-xl p-8 flex flex-col md:flex-row items-center justify-between gap-6 border border-surface-variant/30">
                <div class="pl-2">
                    <h3 class="text-xl font-bold text-on-surface">Acciones Rápidas</h3>
                    <p class="text-sm text-on-surface-variant mt-1">Gestión inmediata de flujo</p>
                </div>
                <div class="flex flex-wrap gap-4">
                    {{ btn.primary('Registrar Turno', 'add_circle') }}
                    {{ btn.secondary('Ver Listado de Hoy', 'list_alt') }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
