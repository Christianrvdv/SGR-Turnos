{# templates/admin/usuarios/index.html.twig #}
{% extends 'admin/layout.html.twig' %}
{% import 'components/buttons.html.twig' as btn %}

{% block title %}Gestión de Usuarios - SGR-Turnos{% endblock %}

{% block body %}
    <div class="max-w-7xl mx-auto space-y-8">
        {# Header Section #}
        <div class="flex justify-between items-end pl-6 border-l-4 border-primary/30">
            <div>
                <h2 class="text-4xl font-bold font-headline text-on-surface tracking-tight">Gestión de Usuarios</h2>
                <p class="text-lg text-on-surface-variant mt-2 font-medium">Administra el acceso y roles de la
                    plataforma.</p>
            </div>
            {{ btn.primary('Nuevo Usuario', 'person_add') }}
        </div>

        {# Toolbar & Filter Section #}
        <div class="bg-surface-container-lowest rounded-xl p-4 sunken-shadow flex items-center justify-between">
            <form method="get" class="relative w-96">
                <span
                    class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline">search</span>
                <input
                    type="text"
                    name="search"
                    value="{{ search }}"
                    class="w-full bg-surface-container-low border-none rounded-lg py-3 pl-10 pr-4 text-sm text-on-surface placeholder:text-outline-variant focus:ring-2 focus:ring-primary/20 transition-shadow"
                    placeholder="Buscar por nombre, usuario o email"
                >
                {% if search %}
                    <a href="{{ path('admin_usuarios_index') }}"
                       class="absolute right-3 top-1/2 -translate-y-1/2 text-outline hover:text-on-surface">
                        <span class="material-symbols-outlined text-[18px]">close</span>
                    </a>
                {% endif %}
            </form>
            <div class="flex gap-3">
                <button
                    class="px-4 py-2 text-sm font-medium text-on-surface-variant bg-surface-container-low rounded-lg hover:bg-surface-container-high transition-colors flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">filter_list</span>
                    Filtros
                </button>
            </div>
        </div>

        {# Data Table #}
        <div class="bg-surface-container-lowest rounded-xl sunken-shadow overflow-hidden">
            <table class="w-full text-left border-collapse">
                <thead>
                <tr class="bg-surface-container border-b border-outline-variant/20">
                    <th class="py-4 px-6 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">
                        Usuario
                    </th>
                    <th class="py-4 px-6 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Nombre
                        de Usuario
                    </th>
                    <th class="py-4 px-6 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Email
                    </th>
                    <th class="py-4 px-6 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Rol
                    </th>
                    <th class="py-4 px-6 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">
                        Estado
                    </th>
                    <th class="py-4 px-6 text-xs font-semibold text-on-surface-variant uppercase tracking-wider text-right">
                        Acciones
                    </th>
                </tr>
                </thead>
                <tbody class="divide-y divide-outline-variant/10">
                {% for usuario in usuarios %}
                    <tr class="group hover:bg-surface-container-low transition-colors duration-150">
                        <td class="py-4 px-6">
                            <div class="flex items-center gap-3">
                                <div
                                    class="h-8 w-8 rounded-full bg-primary-fixed flex items-center justify-center text-on-primary-fixed font-bold text-xs">
                                    {{ usuario.nombreCompleto|slice(0,2)|upper }}
                                </div>
                                <span class="font-medium text-on-surface">{{ usuario.nombreCompleto }}</span>
                            </div>
                        </td>
                        <td class="py-4 px-6 text-on-surface-variant">{{ usuario.nombreUsuario }}</td>
                        <td class="py-4 px-6 text-on-surface-variant">{{ usuario.email }}</td>
                        <td class="py-4 px-6">
                            {% set rolNombre = usuario.rol ? usuario.rol.nombre : 'Sin rol' %}
                            {% set rolClase = {
                                'ROLE_SUPER_ADMIN': 'bg-primary-fixed text-on-primary-fixed',
                                'ROLE_ADMIN': 'bg-primary-fixed text-on-primary-fixed',
                                'ROLE_SUPERVISOR': 'bg-secondary-fixed-dim text-on-secondary-fixed-variant',
                                'ROLE_OPERADOR': 'bg-secondary-fixed-dim text-on-secondary-fixed-variant',
                                'ROLE_OPERADOR_BASICO': 'bg-surface-container-high text-on-surface-variant',
                            } %}
                            <span
                                class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium {{ rolClase[rolNombre]|default('bg-surface-container-high text-on-surface-variant') }}">
                                {{ rolNombre|replace({'ROLE_': ''})|capitalize }}
                            </span>
                        </td>
                        <td class="py-4 px-6">
                            {% if usuario.activo %}
                                <span
                                    class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-secondary-container text-on-secondary-container">
                                    Activo
                                </span>
                            {% else %}
                                <span
                                    class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-error-container text-on-error-container">
                                    Inactivo
                                </span>
                            {% endif %}
                        </td>
                        <td class="py-4 px-6 text-right">
                            <div class="flex justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                {{ btn.icon('edit', null, {title: 'Editar'}) }}
                                {% if usuario.activo %}
                                    {{ btn.icon('block', null, {title: 'Desactivar', class: 'hover:text-error hover:bg-error-container'}) }}
                                {% else %}
                                    {{ btn.icon('check_circle', null, {title: 'Activar'}) }}
                                {% endif %}
                                {{ btn.icon('delete', null, {title: 'Eliminar', class: 'hover:text-error hover:bg-error-container'}) }}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="py-12 text-center text-on-surface-variant">
                            <span class="material-symbols-outlined text-4xl mb-2">person_off</span>
                            <p class="text-lg font-medium">No se encontraron usuarios</p>
                            <p class="text-sm">Intenta con otros términos de búsqueda</p>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>

            {# Pagination Footer #}
            <div
                class="bg-surface-container-lowest px-6 py-4 border-t border-outline-variant/20 flex items-center justify-between">
            <span class="text-sm text-on-surface-variant">
                {% if totalUsuarios > 0 %}
                    Mostrando {{ ((currentPage - 1) * limit) + 1 }} a {{ min(currentPage * limit, totalUsuarios) }} de {{ totalUsuarios }} usuarios
                {% else %}
                    No hay usuarios registrados
                {% endif %}
            </span>
                <div class="flex gap-2">
                    {% if currentPage > 1 %}
                        <a href="{{ path('admin_usuarios_index', {page: currentPage - 1, search: search}) }}"
                           class="px-3 py-1.5 text-sm font-medium text-on-surface-variant bg-surface-container-low rounded-lg hover:bg-surface-container-high transition-colors">
                            Anterior
                        </a>
                    {% else %}
                        <button disabled
                                class="px-3 py-1.5 text-sm font-medium text-on-surface-variant/50 bg-surface-container-low rounded-lg cursor-not-allowed">
                            Anterior
                        </button>
                    {% endif %}

                    {% if currentPage < totalPages %}
                        <a href="{{ path('admin_usuarios_index', {page: currentPage + 1, search: search}) }}"
                           class="px-3 py-1.5 text-sm font-medium text-on-surface bg-surface-container-low rounded-lg hover:bg-surface-container-high transition-colors">
                            Siguiente
                        </a>
                    {% else %}
                        <button disabled
                                class="px-3 py-1.5 text-sm font-medium text-on-surface-variant/50 bg-surface-container-low rounded-lg cursor-not-allowed">
                            Siguiente
                        </button>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
