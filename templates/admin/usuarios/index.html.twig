{# templates/admin/usuarios/index.html.twig #}
{% extends 'admin/layout.html.twig' %}
{% import 'components/buttons.html.twig' as btn %}

{% block title %}Gestión de Usuarios - SGR-Turnos{% endblock %}

{% block body %}
    <div class="max-w-7xl mx-auto space-y-8">
        {# Header Section #}
        <div class="flex justify-between items-end pl-6 border-l-4 border-primary/30">
            <div>
                <h2 class="text-4xl font-bold font-headline text-on-surface tracking-tight">Gestión de Usuarios</h2>
                <p class="text-lg text-on-surface-variant mt-2 font-medium">Administra el acceso y roles de la
                    plataforma.</p>
            </div>
            {{ btn.primary('Nuevo Usuario', 'person_add', null, {
                'onclick': "openModal('modalCrearUsuario')"
            }) }}
        </div>

        {# Toolbar & Filter Section #}
        <div class="bg-surface-container-lowest rounded-xl p-4 sunken-shadow flex items-center justify-between">
            <form method="get" class="relative w-96">
                <span
                    class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline">search</span>
                <input
                    type="text"
                    name="search"
                    value="{{ search }}"
                    class="w-full bg-surface-container-low border-none rounded-lg py-3 pl-10 pr-4 text-sm text-on-surface placeholder:text-outline-variant focus:ring-2 focus:ring-primary/20 transition-shadow"
                    placeholder="Buscar por nombre, usuario o email"
                >
                {% if search %}
                    <a href="{{ path('admin_usuarios_index') }}"
                       class="absolute right-3 top-1/2 -translate-y-1/2 text-outline hover:text-on-surface">
                        <span class="material-symbols-outlined text-[18px]">close</span>
                    </a>
                {% endif %}
            </form>
            <div class="flex gap-3">
                <button
                    class="px-4 py-2 text-sm font-medium text-on-surface-variant bg-surface-container-low rounded-lg hover:bg-surface-container-high transition-colors flex items-center gap-2">
                    <span class="material-symbols-outlined text-[18px]">filter_list</span>
                    Filtros
                </button>
            </div>
        </div>

        {# Data Table #}
        <div class="bg-surface-container-lowest rounded-xl sunken-shadow overflow-hidden">
            <table class="w-full text-left border-collapse">
                <thead>
                <tr class="bg-surface-container border-b border-outline-variant/20">
                    <th class="py-4 pl-6 pr-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">
                        Usuario
                    </th>
                    <th class="py-4 px-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Nombre
                        de Usuario
                    </th>
                    <th class="py-4 px-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Email
                    </th>
                    <th class="py-4 px-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">Rol
                    </th>
                    <th class="py-4 px-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">
                        Estado
                    </th>
                    <th class="py-4 pr-6 pl-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider text-right">
                        Acciones
                    </th>
                </tr>
                </thead>
                <tbody>
                {% for usuario in usuarios %}
                    <tr class="group hover:bg-surface-container-low transition-colors duration-150">
                        <td class="py-4 pl-6 pr-4">
                            <div class="flex items-center gap-3">
                                <div
                                    class="h-8 w-8 rounded-full bg-primary-fixed flex items-center justify-center text-on-primary-fixed font-bold text-xs">
                                    {{ usuario.nombreCompleto|slice(0,2)|upper }}
                                </div>
                                <span class="font-medium text-on-surface">{{ usuario.nombreCompleto }}</span>
                            </div>
                        </td>
                        <td class="py-4 px-4 text-on-surface-variant">{{ usuario.nombreUsuario }}</td>
                        <td class="py-4 px-4 text-on-surface-variant">{{ usuario.email }}</td>
                        <td class="py-4 px-4">
                            {% set rolNombre = usuario.rol ? usuario.rol.nombre : 'Sin rol' %}
                            {% set rolClase = {
                                'ROLE_SUPER_ADMIN': 'bg-primary-fixed text-on-primary-fixed',
                                'ROLE_ADMIN': 'bg-primary-fixed text-on-primary-fixed',
                                'ROLE_SUPERVISOR': 'bg-secondary-fixed-dim text-on-secondary-fixed-variant',
                                'ROLE_OPERADOR': 'bg-secondary-fixed-dim text-on-secondary-fixed-variant',
                                'ROLE_OPERADOR_BASICO': 'bg-surface-container-high text-on-surface-variant',
                            } %}
                            <span
                                class="inline-flex items-center px-2.5 py-1 rounded-full text-[10px] font-medium {{ rolClase[rolNombre]|default('bg-surface-container-high text-on-surface-variant') }}">
                    {{ rolNombre|replace({'ROLE_': ''})|capitalize }}
                </span>
                        </td>
                        <td class="py-4 px-4">
                            {% if usuario.activo %}
                                <span
                                    class="inline-flex items-center px-2.5 py-1 rounded-full text-[10px] font-medium bg-secondary-container text-on-secondary-container">
                        Activo
                    </span>
                            {% else %}
                                <span
                                    class="inline-flex items-center px-2.5 py-1 rounded-full text-[10px] font-medium bg-error-container text-on-error-container">
                        Inactivo
                    </span>
                            {% endif %}
                        </td>
                        <td class="py-4 pr-6 pl-4 text-right">
                            <div class="flex justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                {{ btn.icon('edit', null, {title: 'Editar'}) }}
                                {% if usuario.activo %}
                                    {{ btn.icon('block', null, {title: 'Desactivar', class: 'hover:text-error hover:bg-error-container'}) }}
                                {% else %}
                                    {{ btn.icon('check_circle', null, {title: 'Activar'}) }}
                                {% endif %}
                                {{ btn.icon('delete', null, {title: 'Eliminar', class: 'hover:text-error hover:bg-error-container'}) }}
                            </div>
                        </td>
                    </tr>
                    {# Espaciador #}
                    <tr>
                        <td class="h-px bg-surface-container-low" colspan="6"></td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="py-12 text-center text-on-surface-variant">
                            <span class="material-symbols-outlined text-4xl mb-2">person_off</span>
                            <p class="text-lg font-medium">No se encontraron usuarios</p>
                            <p class="text-sm">Intenta con otros términos de búsqueda</p>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>

            {# Pagination#}
            <div
                class="bg-surface-container-lowest px-6 py-4 border-t border-outline-variant/20 flex items-center justify-between">
    <span class="text-sm text-on-surface-variant">
        {% if totalUsuarios > 0 %}
            Mostrando {{ ((currentPage - 1) * limit) + 1 }} a {{ min(currentPage * limit, totalUsuarios) }} de {{ totalUsuarios }} usuarios
        {% else %}
            No hay usuarios registrados
        {% endif %}
    </span>
                <div class="flex items-center gap-1">
                    {% if currentPage > 1 %}
                        <a href="{{ path('admin_usuarios_index', {page: currentPage - 1, search: search}) }}"
                           class="p-2 rounded-full hover:bg-surface-container-low text-on-surface-variant hover:text-primary transition-colors">
                            <span class="material-symbols-outlined text-[20px]">chevron_left</span>
                        </a>
                    {% else %}
                        <button disabled class="p-2 rounded-full text-outline/50 cursor-not-allowed">
                            <span class="material-symbols-outlined text-[20px]">chevron_left</span>
                        </button>
                    {% endif %}

                    {# Números de página con elipsis #}
                    {% for i in 1..totalPages %}
                        {% if i == currentPage %}
                            <span
                                class="w-8 h-8 flex items-center justify-center rounded-lg bg-primary text-on-primary font-medium text-sm">{{ i }}</span>
                        {% elseif i <= 3 or i > totalPages - 3 or (i >= currentPage - 1 and i <= currentPage + 1) %}
                            <a href="{{ path('admin_usuarios_index', {page: i, search: search}) }}"
                               class="w-8 h-8 flex items-center justify-center rounded-lg text-on-surface-variant hover:bg-surface-container-low font-medium text-sm transition-colors">
                                {{ i }}
                            </a>
                        {% elseif i == 4 or i == totalPages - 3 %}
                            <span class="text-on-surface-variant px-1">...</span>
                        {% endif %}
                    {% endfor %}

                    {% if currentPage < totalPages %}
                        <a href="{{ path('admin_usuarios_index', {page: currentPage + 1, search: search}) }}"
                           class="p-2 rounded-full hover:bg-surface-container-low text-on-surface-variant hover:text-primary transition-colors">
                            <span class="material-symbols-outlined text-[20px]">chevron_right</span>
                        </a>
                    {% else %}
                        <button disabled class="p-2 rounded-full text-outline/50 cursor-not-allowed">
                            <span class="material-symbols-outlined text-[20px]">chevron_right</span>
                        </button>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    {# ==================== MODAL CREAR USUARIO ==================== #}
    {% embed 'components/modal.html.twig' with {
        id: 'modalCrearUsuario',
        title: 'Crear Nuevo Usuario',
        size: '2xl'
    } %}
        {# Importar botones dentro del embed para que estén disponibles #}
        {% import 'components/buttons.html.twig' as btn %}

        {% block body %}
            <form id="formCrearUsuario" method="post" action="{{ path('admin_usuarios_create') }}" class="space-y-6">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('usuario_create') }}">

                {# Fila 1 #}
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="flex flex-col">
                        <label for="nombreCompleto"
                               class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-2">
                            Nombre Completo <span class="text-error">*</span>
                        </label>
                        <input type="text" id="nombreCompleto" name="nombreCompleto" required
                               class="w-full bg-surface-container-lowest border border-outline-variant/30 rounded-lg px-4 py-3 text-sm text-on-surface placeholder:text-outline-variant focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all"
                               placeholder="Ej: Juan Pérez">
                        <p class="text-xs text-error mt-1 hidden error-message" data-field="nombreCompleto">Este campo
                            es obligatorio</p>
                    </div>
                    <div class="flex flex-col">
                        <label for="nombreUsuario"
                               class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-2">
                            Nombre de Usuario <span class="text-error">*</span>
                        </label>
                        <input type="text" id="nombreUsuario" name="nombreUsuario" required
                               class="w-full bg-surface-container-lowest border border-outline-variant/30 rounded-lg px-4 py-3 text-sm text-on-surface placeholder:text-outline-variant focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all"
                               placeholder="Ej: jperez">
                        <p class="text-xs text-error mt-1 hidden error-message" data-field="nombreUsuario">Este campo es
                            obligatorio</p>
                    </div>
                </div>

                {# Fila 2 #}
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="flex flex-col">
                        <label for="email"
                               class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-2">Email</label>
                        <input type="email" id="email" name="email"
                               class="w-full bg-surface-container-lowest border border-outline-variant/30 rounded-lg px-4 py-3 text-sm text-on-surface placeholder:text-outline-variant focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all"
                               placeholder="juan.perez@empresa.com">
                    </div>
                    <div class="flex flex-col">
                        <label for="password"
                               class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-2">
                            Contraseña <span class="text-error">*</span>
                        </label>
                        <div class="relative">
                            <input type="password" id="password" name="password" required
                                   class="w-full bg-surface-container-lowest border border-outline-variant/30 rounded-lg px-4 py-3 text-sm text-on-surface placeholder:text-outline-variant focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all pr-10"
                                   placeholder="••••••••">
                            <button type="button" onclick="togglePassword()"
                                    class="absolute right-3 top-1/2 -translate-y-1/2 text-on-surface-variant hover:text-primary transition-colors">
                                <span class="material-symbols-outlined text-[20px]" id="togglePasswordIcon">visibility_off</span>
                            </button>
                        </div>
                        <p class="text-xs text-on-surface-variant mt-1">Mínimo 8 caracteres</p>
                        <p class="text-xs text-error mt-1 hidden error-message" data-field="password">La contraseña es
                            obligatoria</p>
                    </div>
                </div>

                {# Fila 3 #}
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-start">
                    <div class="flex flex-col">
                        <label for="rol"
                               class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-2">
                            Rol <span class="text-error">*</span>
                        </label>
                        <div class="relative">
                            <select id="rol" name="rol" required
                                    class="w-full bg-surface-container-lowest border border-outline-variant/30 rounded-lg px-4 py-3 text-sm text-on-surface appearance-none focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all cursor-pointer">
                                <option value="" disabled selected>Seleccione un rol...</option>
                                {% for rol in roles %}
                                    <option
                                        value="{{ rol.id }}">{{ rol.nombre|replace({'ROLE_': ''})|capitalize }}</option>
                                {% endfor %}
                            </select>
                            <span
                                class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-on-surface-variant pointer-events-none">expand_more</span>
                        </div>
                        <p class="text-xs text-error mt-1 hidden error-message" data-field="rol">Debe seleccionar un
                            rol</p>
                    </div>
                    <div class="flex flex-col h-full justify-center pt-6">
                        <label class="flex items-center gap-3 cursor-pointer group w-max">
                            <div class="relative">
                                <input type="checkbox" id="activo" name="activo" checked class="sr-only peer">
                                <div
                                    class="w-11 h-6 bg-surface-container-high peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-primary/20 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-outline-variant after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                            </div>
                            <span
                                class="text-sm font-medium text-on-surface group-hover:text-primary transition-colors">Usuario Activo</span>
                        </label>
                    </div>
                </div>
            </form>
        {% endblock %}

        {% block footer %}
            <div class="flex items-center justify-end gap-4">
                {{ btn.secondary('Cancelar', 'close', null, {
                    'onclick': "closeModal('modalCrearUsuario')",
                    'type': 'button'
                }) }}
                {{ btn.primary('Guardar Usuario', 'save', null, {
                    'onclick': 'submitForm()',
                    'type': 'button'
                }) }}
            </div>
        {% endblock %}
    {% endembed %}

    <script>
        // Limpiar formulario al cerrar modal
        document.getElementById('modalCrearUsuario').addEventListener('modal-closed', function () {
            document.getElementById('formCrearUsuario').reset();
            document.querySelectorAll('.error-message').forEach(el => el.classList.add('hidden'));
            document.querySelectorAll('input, select').forEach(el => {
                el.classList.remove('border-error', 'ring-1', 'ring-error/15');
            });
        });

        // Toggle visibilidad contraseña
        window.togglePassword = function () {
            const input = document.getElementById('password');
            const icon = document.getElementById('togglePasswordIcon');
            if (input.type === 'password') {
                input.type = 'text';
                icon.textContent = 'visibility';
            } else {
                input.type = 'password';
                icon.textContent = 'visibility_off';
            }
        };

        // Validación y envío del formulario
        window.submitForm = function () {
            const form = document.getElementById('formCrearUsuario');
            const required = ['nombreCompleto', 'nombreUsuario', 'password', 'rol'];
            let isValid = true;

            required.forEach(fieldId => {
                const field = document.getElementById(fieldId);
                const error = document.querySelector(`[data-field="${fieldId}"]`);
                if (!field.value.trim()) {
                    field.classList.add('border-error', 'ring-1', 'ring-error/15');
                    if (error) error.classList.remove('hidden');
                    isValid = false;
                } else {
                    field.classList.remove('border-error', 'ring-1', 'ring-error/15');
                    if (error) error.classList.add('hidden');
                }
            });

            // Validación extra de email
            const email = document.getElementById('email');
            if (email.value && !/^\S+@\S+\.\S+$/.test(email.value)) {
                email.classList.add('border-error', 'ring-1', 'ring-error/15');
                isValid = false;
            }

            // Validación de longitud de contraseña
            const password = document.getElementById('password');
            if (password.value.length > 0 && password.value.length < 8) {
                password.classList.add('border-error', 'ring-1', 'ring-error/15');
                const pwdError = document.querySelector('[data-field="password"]');
                if (pwdError) {
                    pwdError.textContent = 'La contraseña debe tener al menos 8 caracteres';
                    pwdError.classList.remove('hidden');
                }
                isValid = false;
            }

            if (isValid) {
                form.submit();
            }
        };
    </script>
{% endblock %}
