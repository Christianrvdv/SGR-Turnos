{# templates/admin/servicios/index.html.twig #}
{% extends 'admin/layout.html.twig' %}
{% import 'components/buttons.html.twig' as btn %}

{% block title %}Gestión de Servicios - SGR-Turnos{% endblock %}

{% block body %}
    <div class="max-w-7xl mx-auto space-y-8">
        {# Header Section #}
        <div class="flex justify-between items-end pl-6 border-l-4 border-primary/30">
            <div>
                <h2 class="text-4xl font-bold font-headline text-on-surface tracking-tight">Gestión de Servicios</h2>
                <p class="text-lg text-on-surface-variant mt-2 font-medium">Administre los tipos de servicios ofrecidos
                    y sus configuraciones.</p>
            </div>
            {{ btn.primary('Nuevo Servicio', 'add_circle', null, {
                'onclick': 'crearServicio()'
            }) }}
        </div>

        {# Toolbar & Filter Section #}
        <div class="bg-surface-container-lowest rounded-xl p-4 sunken-shadow flex items-center justify-between">
            <form method="get" class="relative w-96">
                <span
                    class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline">search</span>
                <input type="text" name="search" value="{{ search }}"
                       class="w-full bg-surface-container-low border-none rounded-lg py-3 pl-10 pr-4 text-sm text-on-surface placeholder:text-outline-variant focus:ring-2 focus:ring-primary/20 transition-shadow"
                       placeholder="Filtrar por código, nombre o descripción">
                {% if search %}
                    <a href="{{ path('admin_servicios_index') }}"
                       class="absolute right-3 top-1/2 -translate-y-1/2 text-outline hover:text-on-surface">
                        <span class="material-symbols-outlined text-[18px]">close</span>
                    </a>
                {% endif %}
            </form>
            <div class="flex gap-2">
                <button
                    class="p-2.5 rounded-lg border border-outline-variant/20 text-on-surface-variant hover:bg-surface-container-low transition-colors">
                    <span class="material-symbols-outlined text-[20px]">filter_list</span>
                </button>
                <button
                    class="p-2.5 rounded-lg border border-outline-variant/20 text-on-surface-variant hover:bg-surface-container-low transition-colors">
                    <span class="material-symbols-outlined text-[20px]">view_column</span>
                </button>
            </div>
        </div>

        {# Data Table #}
        <div class="bg-surface-container-lowest rounded-xl sunken-shadow overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse">
                    <thead>
                    <tr class="bg-surface-container border-b border-outline-variant/20">
                        <th class="py-4 pl-6 pr-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">
                            Código
                        </th>
                        <th class="py-4 px-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">
                            Nombre
                        </th>
                        <th class="py-4 px-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">
                            Reserva Futura
                        </th>
                        <th class="py-4 px-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">
                            Control Frec.
                        </th>
                        <th class="py-4 px-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">
                            Días Bloqueo
                        </th>
                        <th class="py-4 px-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">
                            Estado
                        </th>
                        <th class="py-4 pr-6 pl-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider text-right">
                            Acciones
                        </th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for servicio in servicios %}
                        <tr class="group hover:bg-surface-container-low transition-colors duration-150">
                            <td class="py-4 pl-6 pr-4 font-medium text-on-surface">{{ servicio.codigo }}</td>
                            <td class="py-4 px-4 text-on-surface">{{ servicio.nombre }}</td>
                            <td class="py-4 px-4">
                                {% if servicio.permiteReservaFutura %}
                                    <span
                                        class="inline-flex items-center px-2.5 py-1 rounded-full text-[10px] font-medium bg-secondary-container text-on-secondary-container">Sí</span>
                                {% else %}
                                    <span
                                        class="inline-flex items-center px-2.5 py-1 rounded-full text-[10px] font-medium bg-surface-container-high text-on-surface-variant">No</span>
                                {% endif %}
                            </td>
                            <td class="py-4 px-4">
                                {% if servicio.requiereControlFrecuencia %}
                                    <span
                                        class="inline-flex items-center px-2.5 py-1 rounded-full text-[10px] font-medium bg-secondary-container text-on-secondary-container">Activado</span>
                                {% else %}
                                    <span
                                        class="inline-flex items-center px-2.5 py-1 rounded-full text-[10px] font-medium bg-surface-container-high text-on-surface-variant">Desactivado</span>
                                {% endif %}
                            </td>
                            <td class="py-4 px-4 text-on-surface-variant">{{ servicio.diasBloqueo }}</td>
                            <td class="py-4 px-4">
                                {% if servicio.activo %}
                                    <span
                                        class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-medium bg-green-100 text-green-800">
                                        <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span> Activo
                                    </span>
                                {% else %}
                                    <span
                                        class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-medium bg-surface-container-high text-on-surface-variant">
                                        <span class="w-1.5 h-1.5 rounded-full bg-outline"></span> Inactivo
                                    </span>
                                {% endif %}
                            </td>
                            <td class="py-4 pr-6 pl-4 text-right">
                                <div
                                    class="flex justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                    {# Botón Editar #}
                                    {{ btn.icon('edit', null, {
                                        title: 'Editar',
                                        onclick: "editarServicio("
                                        ~ servicio.id ~ ", "
                                        ~ "'" ~ servicio.codigo|escape('js') ~ "', "
                                        ~ "'" ~ servicio.nombre|escape('js') ~ "', "
                                        ~ "'" ~ (servicio.descripcion|default(''))|escape('js') ~ "', "
                                        ~ (servicio.permiteReservaFutura ? 'true' : 'false') ~ ", "
                                        ~ (servicio.requiereControlFrecuencia ? 'true' : 'false') ~ ", "
                                        ~ servicio.diasBloqueo ~ ", "
                                        ~ (servicio.activo ? 'true' : 'false')
                                        ~ ")"
                                    }) }}

                                    {# Formulario Activar/Desactivar #}
                                    <form method="post"
                                          action="{{ path('admin_servicios_toggle_activo', {id: servicio.id}) }}"
                                          class="inline"
                                          onsubmit="return confirm('¿Estás seguro de cambiar el estado de este servicio?')">
                                        <input type="hidden" name="_csrf_token"
                                               value="{{ csrf_token('servicio_toggle_' ~ servicio.id) }}">
                                        <button type="submit" title="{{ servicio.activo ? 'Desactivar' : 'Activar' }}"
                                                class="p-1.5 text-on-surface-variant hover:text-primary transition-colors rounded-lg hover:bg-surface-container-highest {{ servicio.activo ? 'hover:text-error hover:bg-error-container' : '' }}">
                                            <span
                                                class="material-symbols-outlined text-[20px]">{{ servicio.activo ? 'block' : 'check_circle' }}</span>
                                        </button>
                                    </form>

                                    {# Formulario Eliminar #}
                                    <form method="post" action="{{ path('admin_servicios_delete', {id: servicio.id}) }}"
                                          class="inline"
                                          onsubmit="return confirm('¿Estás seguro de eliminar este servicio? Esta acción no se puede deshacer.')">
                                        <input type="hidden" name="_csrf_token"
                                               value="{{ csrf_token('servicio_delete_' ~ servicio.id) }}">
                                        <button type="submit" title="Eliminar"
                                                class="p-1.5 text-on-surface-variant hover:text-error transition-colors rounded-lg hover:bg-error-container">
                                            <span class="material-symbols-outlined text-[20px]">delete</span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        {# Espaciador #}
                        <tr>
                            <td class="h-px bg-surface-container-low" colspan="7"></td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" class="py-12 text-center text-on-surface-variant">
                                <span class="material-symbols-outlined text-4xl mb-2">settings_suggest</span>
                                <p class="text-lg font-medium">No se encontraron servicios</p>
                                <p class="text-sm">Crea un nuevo servicio para comenzar</p>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>

            {# Pagination Footer #}
            <div
                class="bg-surface-container-lowest px-6 py-4 border-t border-outline-variant/20 flex items-center justify-between">
            <span class="text-sm text-on-surface-variant">
                {% if totalServicios > 0 %}
                    Mostrando {{ ((currentPage - 1) * limit) + 1 }} a {{ min(currentPage * limit, totalServicios) }} de {{ totalServicios }} servicios
                {% else %}
                    No hay servicios registrados
                {% endif %}
            </span>
                <div class="flex items-center gap-1">
                    {% if currentPage > 1 %}
                        <a href="{{ path('admin_servicios_index', {page: currentPage - 1, search: search}) }}"
                           class="p-2 rounded-full hover:bg-surface-container-low text-on-surface-variant hover:text-primary transition-colors">
                            <span class="material-symbols-outlined text-[20px]">chevron_left</span>
                        </a>
                    {% else %}
                        <button disabled class="p-2 rounded-full text-outline/50 cursor-not-allowed">
                            <span class="material-symbols-outlined text-[20px]">chevron_left</span>
                        </button>
                    {% endif %}

                    {# Números de página con elipsis #}
                    {% for i in 1..totalPages %}
                        {% if i == currentPage %}
                            <span
                                class="w-8 h-8 flex items-center justify-center rounded-lg bg-primary text-on-primary font-medium text-sm">{{ i }}</span>
                        {% elseif i <= 3 or i > totalPages - 3 or (i >= currentPage - 1 and i <= currentPage + 1) %}
                            <a href="{{ path('admin_servicios_index', {page: i, search: search}) }}"
                               class="w-8 h-8 flex items-center justify-center rounded-lg text-on-surface-variant hover:bg-surface-container-low font-medium text-sm transition-colors">
                                {{ i }}
                            </a>
                        {% elseif i == 4 or i == totalPages - 3 %}
                            <span class="text-on-surface-variant px-1">...</span>
                        {% endif %}
                    {% endfor %}

                    {% if currentPage < totalPages %}
                        <a href="{{ path('admin_servicios_index', {page: currentPage + 1, search: search}) }}"
                           class="p-2 rounded-full hover:bg-surface-container-low text-on-surface-variant hover:text-primary transition-colors">
                            <span class="material-symbols-outlined text-[20px]">chevron_right</span>
                        </a>
                    {% else %}
                        <button disabled class="p-2 rounded-full text-outline/50 cursor-not-allowed">
                            <span class="material-symbols-outlined text-[20px]">chevron_right</span>
                        </button>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    {# ==================== MODAL CREAR/EDITAR SERVICIO ==================== #}
    {% embed 'components/modal.html.twig' with {
        id: 'modalServicio',
        title: 'Nuevo Servicio',
        size: '2xl'
    } %}
        {% import 'components/buttons.html.twig' as btn %}

        {% block body %}
            <form id="formServicio" method="post" action="{{ path('admin_servicios_create') }}" class="space-y-6">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('servicio_create') }}">
                <input type="hidden" name="id" id="servicioId">

                {# Fila 1: Código + Nombre #}
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="flex flex-col">
                        <label for="servicioCodigo"
                               class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-2">
                            Código <span class="text-error">*</span>
                        </label>
                        <input type="text" id="servicioCodigo" name="codigo" required maxlength="20"
                               class="w-full bg-surface-container-lowest border border-outline-variant/30 rounded-lg px-4 py-3 text-sm text-on-surface placeholder:text-outline-variant focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all"
                               placeholder="Ej: CAJ-01">
                        <p class="text-xs text-error mt-1 hidden error-message" data-field="codigo">Este campo es
                            obligatorio</p>
                    </div>
                    <div class="flex flex-col">
                        <label for="servicioNombre"
                               class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-2">
                            Nombre <span class="text-error">*</span>
                        </label>
                        <input type="text" id="servicioNombre" name="nombre" required maxlength="100"
                               class="w-full bg-surface-container-lowest border border-outline-variant/30 rounded-lg px-4 py-3 text-sm text-on-surface placeholder:text-outline-variant focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all"
                               placeholder="Ej: Caja General">
                        <p class="text-xs text-error mt-1 hidden error-message" data-field="nombre">Este campo es
                            obligatorio</p>
                    </div>
                </div>

                {# Fila 2: Descripción #}
                <div class="flex flex-col">
                    <label for="servicioDescripcion"
                           class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-2">Descripción</label>
                    <textarea id="servicioDescripcion" name="descripcion" rows="2" maxlength="255"
                              class="w-full bg-surface-container-lowest border border-outline-variant/30 rounded-lg px-4 py-3 text-sm text-on-surface placeholder:text-outline-variant focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all resize-none"
                              placeholder="Descripción opcional del servicio"></textarea>
                </div>

                {# Fila 3: Configuraciones con Toggles #}
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-start">
                    <div class="space-y-4">
                        <label class="flex items-center gap-3 cursor-pointer group w-max">
                            <div class="relative">
                                <input type="checkbox" id="servicioPermiteReservaFutura" name="permiteReservaFutura"
                                       checked class="sr-only peer">
                                <div
                                    class="w-11 h-6 bg-surface-container-high peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-primary/20 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-outline-variant after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                            </div>
                            <span
                                class="text-sm font-medium text-on-surface group-hover:text-primary transition-colors">Permite Reserva Futura</span>
                        </label>
                        <label class="flex items-center gap-3 cursor-pointer group w-max">
                            <div class="relative">
                                <input type="checkbox" id="servicioRequiereControlFrecuencia"
                                       name="requiereControlFrecuencia" checked class="sr-only peer">
                                <div
                                    class="w-11 h-6 bg-surface-container-high peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-primary/20 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-outline-variant after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                            </div>
                            <span
                                class="text-sm font-medium text-on-surface group-hover:text-primary transition-colors">Requiere Control de Frecuencia</span>
                        </label>
                    </div>
                    <div class="flex flex-col">
                        <label for="servicioDiasBloqueo"
                               class="text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-2">Días
                            de Bloqueo</label>
                        <input type="number" id="servicioDiasBloqueo" name="diasBloqueo" min="0" max="365" value="7"
                               class="w-full bg-surface-container-lowest border border-outline-variant/30 rounded-lg px-4 py-3 text-sm text-on-surface placeholder:text-outline-variant focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all">
                        <p class="text-xs text-on-surface-variant mt-1">0 = sin bloqueo</p>
                    </div>
                </div>

                {# Fila 4: Estado Activo #}
                <div class="flex flex-col h-full justify-center pt-2">
                    <label class="flex items-center gap-3 cursor-pointer group w-max">
                        <div class="relative">
                            <input type="checkbox" id="servicioActivo" name="activo" checked class="sr-only peer">
                            <div
                                class="w-11 h-6 bg-surface-container-high peer-focus:outline-none peer-focus:ring-4 peer-focus:ring-primary/20 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-outline-variant after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                        </div>
                        <span class="text-sm font-medium text-on-surface group-hover:text-primary transition-colors">Servicio Activo</span>
                    </label>
                </div>
            </form>
        {% endblock %}

        {% block footer %}
            <div class="flex items-center justify-end gap-4">
                {{ btn.secondary('Cancelar', 'close', null, {
                    'onclick': "closeModal('modalServicio')",
                    'type': 'button'
                }) }}
                {{ btn.primary('Guardar Servicio', 'save', null, {
                    'onclick': 'submitServicioForm()',
                    'type': 'button'
                }) }}
            </div>
        {% endblock %}
    {% endembed %}

    <script>
        const modalServicio = document.getElementById('modalServicio');
        const formServicio = document.getElementById('formServicio');
        const modalTitle = document.querySelector('#modalServicio h2');

        // Función para abrir modal en modo creación
        window.crearServicio = function () {
            modalTitle.textContent = 'Nuevo Servicio';
            formServicio.action = '{{ path('admin_servicios_create') }}';
            formServicio.reset();
            document.getElementById('servicioId').value = '';
            document.querySelectorAll('.error-message').forEach(el => el.classList.add('hidden'));
            openModal('modalServicio');
        };

        // Función para abrir modal en modo edición
        window.editarServicio = function (id, codigo, nombre, descripcion, permiteReserva, requiereControl, diasBloqueo, activo) {
            modalTitle.textContent = 'Editar Servicio';
            formServicio.action = '{{ path('admin_servicios_update', {id: 'PLACEHOLDER'}) }}'.replace('PLACEHOLDER', id);
            document.getElementById('servicioId').value = id;
            document.getElementById('servicioCodigo').value = codigo;
            document.getElementById('servicioNombre').value = nombre;
            document.getElementById('servicioDescripcion').value = descripcion || '';
            document.getElementById('servicioPermiteReservaFutura').checked = permiteReserva;
            document.getElementById('servicioRequiereControlFrecuencia').checked = requiereControl;
            document.getElementById('servicioDiasBloqueo').value = diasBloqueo;
            document.getElementById('servicioActivo').checked = activo;
            document.querySelectorAll('.error-message').forEach(el => el.classList.add('hidden'));
            openModal('modalServicio');
        };

        // Limpiar formulario al cerrar
        modalServicio.addEventListener('modal-closed', function () {
            formServicio.reset();
            document.querySelectorAll('.error-message').forEach(el => el.classList.add('hidden'));
            document.querySelectorAll('input, select, textarea').forEach(el => {
                el.classList.remove('border-error', 'ring-1', 'ring-error/15');
            });
        });

        // Validación y envío
        window.submitServicioForm = function () {
            const required = ['servicioCodigo', 'servicioNombre'];
            let isValid = true;

            required.forEach(fieldId => {
                const field = document.getElementById(fieldId);
                const error = document.querySelector(`[data-field="${fieldId.replace('servicio', '').toLowerCase()}"]`);
                if (!field.value.trim()) {
                    field.classList.add('border-error', 'ring-1', 'ring-error/15');
                    if (error) error.classList.remove('hidden');
                    isValid = false;
                } else {
                    field.classList.remove('border-error', 'ring-1', 'ring-error/15');
                    if (error) error.classList.add('hidden');
                }
            });

            if (isValid) {
                formServicio.submit();
            }
        };
    </script>
{% endblock %}
