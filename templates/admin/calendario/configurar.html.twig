{# templates/admin/calendario/configurar.html.twig #}
{% extends 'admin/layout.html.twig' %}
{% import 'components/buttons.html.twig' as btn %}

{% block title %}Configurar {{ servicio.nombre }} - {{ fecha|date('d/m/Y') }}{% endblock %}

{% block body %}
    <div class="max-w-7xl mx-auto space-y-8">
        {# Header Section #}
        <div class="flex justify-between items-end pl-6 border-l-4 border-primary/30">
            <div>
                <h2 class="text-4xl font-bold font-headline text-on-surface tracking-tight">Configuración Diaria</h2>
                <p class="text-lg text-on-surface-variant mt-2 font-medium">
                    {{ servicio.nombre }} - {{ fecha|date('l, d F Y')|capitalize }}
                </p>
            </div>
            <div class="flex items-center gap-3">
                <a href="{{ path('admin_calendario_index', {servicio: servicio.id, mes: fecha|date('m'), anio: fecha|date('Y')}) }}"
                   class="px-6 py-3 rounded-full font-semibold text-sm text-on-surface-variant border border-outline-variant/40 hover:bg-surface-container transition-all duration-200 flex items-center gap-2">
                    <span class="material-symbols-outlined text-[20px]">arrow_back</span>
                    Volver al Calendario
                </a>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-start">
            {# Formulario principal #}
            <div class="lg:col-span-2 space-y-6">
                <div class="bg-surface-container-lowest rounded-xl sunken-shadow p-6 md:p-8">
                    <form method="post"
                          action="{{ path('admin_calendario_configurar', {servicioId: servicio.id, fecha: fecha|date('Y-m-d')}) }}"
                          class="space-y-8">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('configuracion_diaria') }}">

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                            {# Columna izquierda #}
                            <div class="space-y-6">
                                <div class="space-y-2">
                                    <label
                                        class="block text-xs font-semibold text-on-surface-variant uppercase tracking-wider pl-1">Fecha</label>
                                    <div class="relative">
                                        <input type="text" readonly
                                               class="w-full bg-surface-container-low border-none rounded-lg py-3 px-4 text-on-surface font-medium cursor-not-allowed opacity-70"
                                               value="{{ fecha|date('d/m/Y') }}">
                                        <span
                                            class="material-symbols-outlined absolute right-3 top-3 text-on-surface-variant/50">lock</span>
                                    </div>
                                </div>

                                <div class="space-y-2">
                                    <label for="montoCargado"
                                           class="block text-xs font-semibold text-on-surface-variant uppercase tracking-wider pl-1">
                                        Monto Cargado (CUP) <span class="text-error">*</span>
                                    </label>
                                    <div class="relative group">
                                        <div
                                            class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                            <span class="text-on-surface-variant font-medium">$</span>
                                        </div>
                                        <input type="number" id="montoCargado" name="montoCargado" required
                                               value="{{ configuracion.montoCargado }}"
                                               class="w-full bg-surface border border-outline-variant/30 rounded-lg py-3 pl-8 pr-4 text-on-surface focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all"
                                               placeholder="Ej. 500000" step="0.01" min="0">
                                    </div>
                                    <p class="text-xs text-error mt-1 hidden error-message" data-field="montoCargado">
                                        Este campo es obligatorio</p>
                                </div>

                                <div class="space-y-2">
                                    <label for="limitePorPersona"
                                           class="block text-xs font-semibold text-on-surface-variant uppercase tracking-wider pl-1">
                                        Límite por Persona (CUP) <span class="text-error">*</span>
                                    </label>
                                    <div class="relative">
                                        <div
                                            class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                                            <span class="text-on-surface-variant font-medium">$</span>
                                        </div>
                                        <input type="number" id="limitePorPersona" name="limitePorPersona" required
                                               value="{{ configuracion.limitePorPersona }}"
                                               class="w-full bg-surface border border-outline-variant/30 rounded-lg py-3 pl-8 pr-4 text-on-surface focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all"
                                               step="0.01" min="0">
                                    </div>
                                    <p class="text-xs text-error mt-1 hidden error-message"
                                       data-field="limitePorPersona">Este campo es obligatorio</p>
                                </div>
                            </div>

                            {# Columna derecha #}
                            <div class="space-y-6">
                                <div class="space-y-2">
                                    <label for="porcentajeReserva"
                                           class="block text-xs font-semibold text-on-surface-variant uppercase tracking-wider pl-1">
                                        Porcentaje de Reserva (%)
                                    </label>
                                    <div class="relative">
                                        <input type="number" id="porcentajeReserva" name="porcentajeReserva"
                                               value="{{ configuracion.porcentajeReserva }}"
                                               class="w-full bg-surface border border-outline-variant/30 rounded-lg py-3 px-4 text-on-surface focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all"
                                               min="0" max="100" step="0.01">
                                        <div
                                            class="absolute inset-y-0 right-0 pr-4 flex items-center pointer-events-none">
                                            <span class="text-on-surface-variant text-sm">%</span>
                                        </div>
                                    </div>
                                </div>

                                <div class="space-y-2">
                                    <label
                                        class="block text-xs font-semibold text-on-surface-variant uppercase tracking-wider pl-1">Tickets
                                        Generados</label>
                                    <div
                                        class="w-full bg-primary/5 border border-primary/10 rounded-lg py-3 px-4 flex justify-between items-center">
                                    <span class="text-3xl font-bold text-primary">
                                        {{ configuracion.ticketsGenerados ? configuracion.ticketsGenerados : '--' }}
                                    </span>
                                        <span
                                            class="text-xs font-medium text-primary bg-primary/10 px-2 py-1 rounded-full">
                                        {{ configuracion.ticketsGenerados ? 'Calculado' : 'Pendiente' }}
                                    </span>
                                    </div>
                                </div>

                                <div class="space-y-2">
                                    <label for="estado"
                                           class="block text-xs font-semibold text-on-surface-variant uppercase tracking-wider pl-1">Estado</label>
                                    <div class="relative">
                                        <select id="estado" name="estado"
                                                class="w-full bg-surface border border-outline-variant/30 rounded-lg py-3 pl-4 pr-10 text-on-surface appearance-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all font-medium">
                                            {% for estado in estados %}
                                                <option
                                                    value="{{ estado.value }}" {{ configuracion.estado.value == estado.value ? 'selected' : '' }}>
                                                    {{ estado.value }}
                                                </option>
                                            {% endfor %}
                                        </select>
                                        <span
                                            class="material-symbols-outlined absolute right-3 top-3 text-on-surface-variant pointer-events-none">expand_more</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        {# Botones de acción #}
                        <div
                            class="mt-8 pt-6 border-t border-outline-variant/20 flex flex-col sm:flex-row justify-end gap-4">
                            <button type="button" onclick="calcularCapacidad()"
                                    class="px-6 py-3 rounded-full font-semibold text-sm text-primary border border-outline-variant/40 hover:bg-primary/5 hover:border-primary/30 transition-all duration-200 flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined text-[20px]">calculate</span>
                                Calcular Capacidad
                            </button>
                            <button type="submit"
                                    class="gradient-btn text-on-primary px-8 py-3 rounded-full font-semibold text-sm transition-all duration-200 hover:shadow-lg hover:-translate-y-0.5 active:translate-y-0 active:shadow-md flex items-center justify-center gap-2">
                                <span class="material-symbols-outlined text-[20px]">save</span>
                                Guardar Configuración
                            </button>
                        </div>
                    </form>
                </div>

                {# Tabla de Distribución (Vista Previa) #}
                <div class="bg-surface-container-lowest rounded-xl sunken-shadow overflow-hidden">
                    <div class="p-5 border-b border-outline-variant/20 flex justify-between items-center">
                        <h3 class="text-lg font-semibold text-on-surface">Vista Previa de Distribución</h3>
                        <button onclick="calcularCapacidad()"
                                class="text-primary hover:bg-primary/5 p-2 rounded-full transition-colors">
                            <span class="material-symbols-outlined text-[20px]">refresh</span>
                        </button>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left text-sm">
                            <thead>
                            <tr class="bg-surface-container border-b border-outline-variant/20">
                                <th class="py-3 pl-6 pr-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">
                                    Rango Horario
                                </th>
                                <th class="py-3 px-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">
                                    Tickets Disponibles
                                </th>
                                <th class="py-3 pr-6 pl-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">
                                    Estado
                                </th>
                            </tr>
                            </thead>
                            <tbody id="distribucion-body">
                            <tr>
                                <td colspan="3" class="py-12 text-center text-on-surface-variant">
                                    <span class="material-symbols-outlined text-4xl mb-2">calculate</span>
                                    <p class="text-lg font-medium">Ingresa los datos y presiona "Calcular Capacidad"</p>
                                    <p class="text-sm">para ver la distribución estimada de tickets.</p>
                                </td>
                            </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            {# Sidebar derecho #}
            <div class="lg:col-span-1 space-y-6">
                {# Información del servicio #}
                <div class="bg-surface-container-lowest rounded-xl sunken-shadow p-6">
                    <h4 class="text-sm font-semibold text-on-surface mb-4 flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">info</span>
                        Información del Servicio
                    </h4>
                    <div class="space-y-3 text-sm">
                        <div class="flex justify-between">
                            <span class="text-on-surface-variant">Código:</span>
                            <span class="font-medium text-on-surface">{{ servicio.codigo }}</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-on-surface-variant">Reserva Futura:</span>
                            <span
                                class="font-medium text-on-surface">{{ servicio.permiteReservaFutura ? 'Sí' : 'No' }}</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-on-surface-variant">Control Frecuencia:</span>
                            <span
                                class="font-medium text-on-surface">{{ servicio.requiereControlFrecuencia ? 'Activado' : 'Desactivado' }}</span>
                        </div>
                        <div class="flex justify-between">
                            <span class="text-on-surface-variant">Días Bloqueo:</span>
                            <span class="font-medium text-on-surface">{{ servicio.diasBloqueo }}</span>
                        </div>
                    </div>
                </div>

                {# Acciones rápidas #}
                <div class="bg-gradient-to-br from-surface-container-low to-surface-container rounded-xl p-6">
                    <h4 class="text-sm font-semibold text-on-surface mb-4">Acciones Rápidas</h4>
                    <div class="space-y-3">
                        <a href="{{ path('admin_calendario_index', {servicio: servicio.id, mes: fecha|date('m'), anio: fecha|date('Y')}) }}"
                           class="w-full px-4 py-2.5 rounded-full text-sm font-medium text-on-surface-variant border border-outline-variant/40 hover:bg-surface-container transition-all flex items-center justify-center gap-2">
                            <span class="material-symbols-outlined text-[20px]">calendar_month</span>
                            Ver Calendario
                        </a>
                    </div>
                </div>

                {# Leyenda de estados #}
                <div class="bg-surface-container-lowest rounded-xl sunken-shadow p-6">
                    <h4 class="text-sm font-semibold text-on-surface mb-3">Estados de Configuración</h4>
                    <div class="space-y-2 text-xs">
                        <div class="flex items-center gap-2">
                            <span class="w-3 h-3 rounded-full bg-green-500"></span>
                            <span class="text-on-surface-variant">ABIERTA: Acepta turnos</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="w-3 h-3 rounded-full bg-error"></span>
                            <span class="text-on-surface-variant">CERRADA: No acepta turnos</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="w-3 h-3 rounded-full bg-outline"></span>
                            <span class="text-on-surface-variant">FINALIZADA: Día completado</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function calcularCapacidad() {
            // Simulación de cálculo de distribución
            const monto = document.getElementById('montoCargado').value;
            const limite = document.getElementById('limitePorPersona').value;

            if (!monto || !limite) {
                alert('Ingrese el monto cargado y el límite por persona para calcular la capacidad.');
                return;
            }

            const ticketsEstimados = Math.floor(monto / limite);
            const tbody = document.getElementById('distribucion-body');

            // Distribución simulada por horas
            const horas = ['08:00 - 09:00', '09:00 - 10:00', '10:00 - 11:00', '11:00 - 12:00', '12:00 - 13:00'];
            const totalHoras = horas.length;
            const ticketsPorHora = Math.floor(ticketsEstimados / totalHoras);
            let restante = ticketsEstimados % totalHoras;

            let html = '';
            horas.forEach((hora, index) => {
                let tickets = ticketsPorHora;
                if (restante > 0) {
                    tickets++;
                    restante--;
                }
                html += `
                <tr class="group hover:bg-surface-container-low transition-colors duration-150">
                    <td class="py-4 pl-6 pr-4 text-on-surface font-medium">${hora}</td>
                    <td class="py-4 px-4 text-on-surface">${tickets}</td>
                    <td class="py-4 pr-6 pl-4">
                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-medium bg-green-100 text-green-800">
                            <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span> Programado
                        </span>
                    </td>
                </tr>
                <tr><td class="h-px bg-surface-container-low" colspan="3"></td></tr>
            `;
            });

            // Actualizar el campo de tickets generados
            const ticketDisplay = document.querySelector('.text-3xl.font-bold.text-primary');
            if (ticketDisplay) {
                ticketDisplay.textContent = ticketsEstimados;
            }
            const badge = document.querySelector('.text-xs.font-medium.text-primary.bg-primary\\/10');
            if (badge) {
                badge.textContent = 'Calculado';
            }

            tbody.innerHTML = html;
        }

        // Validación del formulario
        document.querySelector('form').addEventListener('submit', function (e) {
            const monto = document.getElementById('montoCargado');
            const limite = document.getElementById('limitePorPersona');
            let isValid = true;

            if (!monto.value) {
                monto.classList.add('border-error', 'ring-1', 'ring-error/15');
                document.querySelector('[data-field="montoCargado"]').classList.remove('hidden');
                isValid = false;
            } else {
                monto.classList.remove('border-error', 'ring-1', 'ring-error/15');
                document.querySelector('[data-field="montoCargado"]').classList.add('hidden');
            }

            if (!limite.value) {
                limite.classList.add('border-error', 'ring-1', 'ring-error/15');
                document.querySelector('[data-field="limitePorPersona"]').classList.remove('hidden');
                isValid = false;
            } else {
                limite.classList.remove('border-error', 'ring-1', 'ring-error/15');
                document.querySelector('[data-field="limitePorPersona"]').classList.add('hidden');
            }

            if (!isValid) {
                e.preventDefault();
            }
        });
    </script>
{% endblock %}
