{# templates/admin/layout.html.twig #}
<!DOCTYPE html>
<html class="light" lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}SGR-Turnos Admin{% endblock %}</title>

    {# Fuentes e íconos #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet"
          href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0,1"/>

    {% block stylesheets %}
        <link rel="stylesheet" href="{{ asset('css/tailwind.css') }}">
    {% endblock %}
    {% block javascripts %}{% endblock %}
</head>
<body class="bg-surface text-on-surface antialiased min-h-screen flex overflow-hidden">

{# Barra lateral #}
<nav
    class="h-screen w-72 fixed left-0 top-0 overflow-y-auto bg-surface-container-lowest shadow-2xl shadow-on-surface/5 z-50 flex flex-col">
    <div class="p-6 pb-2 border-b-0">
        <h1 class="text-2xl font-bold text-primary tracking-tight">SGR-Turnos</h1>
        <p class="text-sm font-medium text-on-surface-variant mt-1">Administración Central</p>
    </div>
    <div class="flex flex-col gap-2 p-6 flex-grow">
        {% set ruta_actual = app.request.attributes.get('_route') %}

        <a href="{{ path('admin_dashboard') }}"
           class="flex items-center gap-3 px-4 py-3 {{ ruta_actual starts with 'admin_dashboard' ? 'text-primary font-semibold bg-surface-container' : 'text-on-surface-variant font-medium hover:bg-surface-container' }} rounded-lg transition-all duration-200">
            <span
                class="material-symbols-outlined" {{ ruta_actual starts with 'admin_dashboard' ? 'style="font-variation-settings: \'FILL\' 1;"' : '' }}>dashboard</span>
            Dashboard
        </a>
        <a href="{{ path('admin_usuarios_index') }}"
           class="flex items-center gap-3 px-4 py-3 {{ ruta_actual starts with 'admin_usuarios' ? 'text-primary font-semibold bg-surface-container' : 'text-on-surface-variant font-medium hover:bg-surface-container' }} rounded-lg transition-all duration-200">
            <span
                class="material-symbols-outlined" {{ ruta_actual starts with 'admin_usuarios' ? 'style="font-variation-settings: \'FILL\' 1;"' : '' }}>group</span>
            Usuarios
        </a>
        <a href="{{ path('admin_servicios_index') }}"
           class="flex items-center gap-3 px-4 py-3 {{ ruta_actual starts with 'admin_servicios' ? 'text-primary font-semibold bg-surface-container' : 'text-on-surface-variant font-medium hover:bg-surface-container' }} rounded-lg transition-all duration-200">
            <span
                class="material-symbols-outlined" {{ ruta_actual starts with 'admin_servicios' ? 'style="font-variation-settings: \'FILL\' 1;"' : '' }}>settings_suggest</span>
            Servicios
        </a>
        <a href="#"
           class="flex items-center gap-3 px-4 py-3 text-on-surface-variant font-medium hover:bg-surface-container rounded-lg transition-all duration-200">
            <span class="material-symbols-outlined">calendar_today</span>
            Calendario
        </a>
        <a href="#"
           class="flex items-center gap-3 px-4 py-3 text-on-surface-variant font-medium hover:bg-surface-container rounded-lg transition-all duration-200">
            <span class="material-symbols-outlined">history_edu</span>
            Auditoría
        </a>
    </div>
    <div class="p-6 mt-auto">
        <div
            class="flex items-center gap-3 px-4 py-3 rounded-lg bg-surface-container-low cursor-pointer hover:bg-surface-container transition-colors">
            <div
                class="w-10 h-10 rounded-full bg-primary-fixed flex items-center justify-center text-primary-fixed-variant font-bold">
                {{ app.user.nombreCompleto|slice(0,1)|upper }}
            </div>
            <div class="flex-1 min-w-0">
                <p class="text-sm font-semibold text-on-surface truncate">{{ app.user.nombreCompleto }}</p>
                <p class="text-xs text-on-surface-variant truncate">{{ app.user.email }}</p>
            </div>
        </div>
    </div>
</nav>

{# Barra superior #}
<header
    class="fixed top-0 right-0 left-72 h-20 z-40 bg-surface/80 backdrop-blur-xl flex justify-between items-center px-12 transition-all">
    <div class="flex-1 flex items-center">
        <div class="relative w-96 focus-within:ring-2 ring-primary/20 rounded-full transition-all">
            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant">search</span>
            <input type="text"
                   class="w-full bg-surface-container-low border-none rounded-full py-2.5 pl-12 pr-4 text-sm font-medium text-on-surface placeholder-on-surface-variant focus:ring-0 focus:outline-none"
                   placeholder="Buscar turnos, usuarios...">
        </div>
    </div>
    <div class="flex items-center gap-6">
        <h2 class="text-lg font-bold text-on-surface tracking-tight">{{ app.user.nombreCompleto }}</h2>
        <div class="flex gap-2">
            <button
                class="p-2 text-on-surface-variant hover:text-primary rounded-full hover:bg-surface-container transition-colors relative">
                <span class="material-symbols-outlined">notifications</span>
                <span class="absolute top-2 right-2 w-2 h-2 bg-error rounded-full"></span>
            </button>
            <button
                class="p-2 text-on-surface-variant hover:text-primary rounded-full hover:bg-surface-container transition-colors">
                <span class="material-symbols-outlined">settings</span>
            </button>
        </div>
        <div
            class="w-10 h-10 rounded-full bg-primary-fixed flex items-center justify-center text-primary-fixed-variant font-bold">
            {{ app.user.nombreCompleto|slice(0,1)|upper }}
        </div>
    </div>
</header>

{# Contenido principal #}
<main class="flex-1 ml-72 pt-28 px-12 pb-12 overflow-y-auto">
    {% block body %}{% endblock %}
</main>

</body>
</html>
