{# templates/admin/auditoria/index.html.twig #}
{% extends 'admin/layout.html.twig' %}
{% import 'components/buttons.html.twig' as btn %}

{% block title %}Auditoría - SGR-Turnos{% endblock %}

{% block body %}
    <div class="max-w-7xl mx-auto space-y-8">
        {# Header Section #}
        <div class="flex justify-between items-end pl-6 border-l-4 border-primary/30">
            <div>
                <h2 class="text-4xl font-bold font-headline text-on-surface tracking-tight">Registro de Actividad</h2>
                <p class="text-lg text-on-surface-variant mt-2 font-medium">Consulta detallada de todos los eventos y
                    transacciones realizadas en el sistema.</p>
            </div>
            {# Botón de exportar (opcional) #}
            {{ btn.secondary('Exportar', 'download') }}
        </div>

        {# Filtros #}
        <div class="bg-surface-container-lowest rounded-xl p-6 sunken-shadow">
            <form method="get" class="flex flex-col md:flex-row gap-4 items-end">
                <div class="flex-1 w-full">
                    <label
                        class="block text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-2 pl-1">Usuario</label>
                    <div class="relative">
                        <select name="usuario"
                                class="w-full appearance-none bg-surface-container-low border-none text-on-surface text-sm rounded-lg py-3 pl-4 pr-10 focus:ring-2 focus:ring-primary/20 transition-all">
                            <option value="">Todos los usuarios</option>
                            {% for usuario in usuarios %}
                                <option value="{{ usuario.id }}" {{ filtros.usuario == usuario.id ? 'selected' : '' }}>
                                    {{ usuario.nombreUsuario }} ({{ usuario.nombreCompleto }})
                                </option>
                            {% endfor %}
                        </select>
                        <span
                            class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-on-surface-variant pointer-events-none text-[20px]">expand_more</span>
                    </div>
                </div>
                <div class="flex-1 w-full">
                    <label
                        class="block text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-2 pl-1">Tipo
                        de Acción</label>
                    <div class="relative">
                        <select name="accion"
                                class="w-full appearance-none bg-surface-container-low border-none text-on-surface text-sm rounded-lg py-3 pl-4 pr-10 focus:ring-2 focus:ring-primary/20 transition-all">
                            <option value="">Todas las acciones</option>
                            {% for tipo in tiposAccion %}
                                <option
                                    value="{{ tipo }}" {{ filtros.accion == tipo ? 'selected' : '' }}>{{ tipo }}</option>
                            {% endfor %}
                        </select>
                        <span
                            class="material-symbols-outlined absolute right-3 top-1/2 -translate-y-1/2 text-on-surface-variant pointer-events-none text-[20px]">expand_more</span>
                    </div>
                </div>
                <div class="flex-1 w-full">
                    <label
                        class="block text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-2 pl-1">Desde</label>
                    <div class="relative group">
                        <span
                            class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-[18px] group-focus-within:text-primary">calendar_today</span>
                        <input type="date" name="fecha_inicio" value="{{ filtros.fecha_inicio }}"
                               class="w-full bg-surface-container-low border-none text-on-surface text-sm rounded-lg py-3 pl-10 pr-4 focus:ring-2 focus:ring-primary/20 transition-all">
                    </div>
                </div>
                <div class="flex-1 w-full">
                    <label
                        class="block text-xs font-semibold text-on-surface-variant uppercase tracking-wider mb-2 pl-1">Hasta</label>
                    <div class="relative group">
                        <span
                            class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-[18px] group-focus-within:text-primary">calendar_today</span>
                        <input type="date" name="fecha_fin" value="{{ filtros.fecha_fin }}"
                               class="w-full bg-surface-container-low border-none text-on-surface text-sm rounded-lg py-3 pl-10 pr-4 focus:ring-2 focus:ring-primary/20 transition-all">
                    </div>
                </div>
                <div class="flex gap-2">
                    <button type="submit"
                            class="gradient-btn text-on-primary px-6 py-3 rounded-full font-semibold text-sm transition-all duration-200 hover:shadow-lg hover:-translate-y-0.5 active:translate-y-0 active:shadow-md flex items-center gap-2">
                        <span class="material-symbols-outlined text-[20px]">filter_list</span>
                        Filtrar
                    </button>
                    {% if filtros.usuario or filtros.accion or filtros.fecha_inicio or filtros.fecha_fin %}
                        <a href="{{ path('admin_auditoria_index') }}"
                           class="px-6 py-3 rounded-full font-semibold text-sm text-on-surface-variant border border-outline-variant/40 hover:bg-surface-container transition-all duration-200 flex items-center gap-2">
                            <span class="material-symbols-outlined text-[20px]">close</span>
                            Limpiar
                        </a>
                    {% endif %}
                </div>
            </form>
        </div>

        {# Tabla de Auditoría #}
        <div class="bg-surface-container-lowest rounded-xl sunken-shadow overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-left text-sm">
                    <thead>
                    <tr class="bg-surface-container border-b border-outline-variant/20">
                        <th class="py-4 pl-6 pr-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">
                            Fecha y Hora
                        </th>
                        <th class="py-4 px-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">
                            Usuario
                        </th>
                        <th class="py-4 px-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider">
                            Acción
                        </th>
                        <th class="py-4 px-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider w-full">
                            Descripción / Entidad
                        </th>
                        <th class="py-4 pr-6 pl-4 text-xs font-semibold text-on-surface-variant uppercase tracking-wider text-right">
                            IP Origen
                        </th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for auditoria in auditorias %}
                        <tr class="group hover:bg-surface-container-low transition-colors duration-150">
                            <td class="py-4 pl-6 pr-4 text-on-surface font-medium">
                                {{ auditoria.creadoEn|date('d/M/Y') }} <span
                                    class="text-on-surface-variant ml-1 font-normal">{{ auditoria.creadoEn|date('H:i:s') }}</span>
                            </td>
                            <td class="py-4 px-4 text-on-surface">
                                <div class="flex items-center gap-2">
                                    {% if auditoria.usuario %}
                                        <div
                                            class="w-6 h-6 rounded-full bg-primary-fixed flex items-center justify-center text-on-primary-fixed font-bold text-[10px]">
                                            {{ auditoria.usuario.nombreCompleto|slice(0,1)|upper }}
                                        </div>
                                        <span>{{ auditoria.usuario.nombreUsuario }}</span>
                                    {% else %}
                                        <div
                                            class="w-6 h-6 rounded-full bg-surface-variant flex items-center justify-center text-on-surface-variant">
                                            <span class="material-symbols-outlined text-[14px]">smart_toy</span>
                                        </div>
                                        <span class="text-on-surface-variant">Sistema</span>
                                    {% endif %}
                                </div>
                            </td>
                            <td class="py-4 px-4">
                                {% set tipoClase = {
                                    'CREATE': 'bg-primary-fixed text-on-primary-fixed',
                                    'UPDATE': 'bg-secondary-fixed-dim text-on-secondary-fixed-variant',
                                    'DELETE': 'bg-error-container text-on-error-container',
                                    'LOGIN': 'bg-tertiary-fixed text-on-tertiary-fixed',
                                    'LOGOUT': 'bg-surface-container-high text-on-surface-variant',
                                    'TURNO_MARCADO_USADO': 'bg-secondary-container text-on-secondary-container',
                                    'CONFIGURACION_CREADA': 'bg-primary-fixed text-on-primary-fixed',
                                } %}
                                <span
                                    class="inline-flex items-center px-2.5 py-1 rounded-full text-[10px] font-medium {{ tipoClase[auditoria.tipoAccion]|default('bg-surface-container-high text-on-surface-variant') }} border border-outline-variant/20 tracking-wide">
                                    {{ auditoria.tipoAccion }}
                                </span>
                            </td>
                            <td class="py-4 px-4 text-on-surface-variant max-w-[300px] truncate"
                                title="{{ auditoria.entidadAfectada ? auditoria.entidadAfectada ~ ' #' ~ auditoria.entidadId : 'Acción del sistema' }}">
                                {% if auditoria.entidadAfectada %}
                                    {{ auditoria.entidadAfectada }} #{{ auditoria.entidadId }}
                                {% else %}
                                    Acción del sistema
                                {% endif %}
                                {% if auditoria.datosDespues %}
                                    <span
                                        class="material-symbols-outlined text-[14px] align-middle ml-1 text-outline cursor-help"
                                        title="{{ auditoria.datosDespues|json_encode(constant('JSON_PRETTY_PRINT')) }}">info</span>
                                {% endif %}
                            </td>
                            <td class="py-4 pr-6 pl-4 font-mono text-xs text-on-surface-variant text-right tracking-tight">
                                {{ auditoria.ipOrigen|default('localhost') }}
                            </td>
                        </tr>
                        {# Espaciador visual #}
                        <tr>
                            <td class="h-px bg-surface-container-low" colspan="5"></td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="py-12 text-center text-on-surface-variant">
                                <span class="material-symbols-outlined text-4xl mb-2">history_edu</span>
                                <p class="text-lg font-medium">No se encontraron registros de auditoría</p>
                                <p class="text-sm">Ajusta los filtros o espera a que se registren actividades</p>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>

            {# Paginación #}
            <div
                class="bg-surface-container-lowest px-6 py-4 border-t border-outline-variant/20 flex items-center justify-between">
    <span class="text-sm text-on-surface-variant">
        {% if totalRegistros > 0 %}
            Mostrando {{ ((currentPage - 1) * limit) + 1 }} a {{ min(currentPage * limit, totalRegistros) }} de {{ totalRegistros }} registros
        {% else %}
            No hay registros
        {% endif %}
    </span>
                <div class="flex items-center gap-1">
                    {% if currentPage > 1 %}
                        <a href="{{ path('admin_auditoria_index', filtros|merge({page: currentPage - 1})) }}"
                           class="p-2 rounded-full hover:bg-surface-container-low text-on-surface-variant hover:text-primary transition-colors">
                            <span class="material-symbols-outlined text-[20px]">chevron_left</span>
                        </a>
                    {% else %}
                        <button disabled class="p-2 rounded-full text-outline/50 cursor-not-allowed">
                            <span class="material-symbols-outlined text-[20px]">chevron_left</span>
                        </button>
                    {% endif %}

                    {# Números de página con elipsis #}
                    {% for i in 1..totalPages %}
                        {% if i == currentPage %}
                            <span
                                class="w-8 h-8 flex items-center justify-center rounded-lg bg-primary text-on-primary font-medium text-sm">{{ i }}</span>
                        {% elseif i <= 3 or i > totalPages - 3 or (i >= currentPage - 1 and i <= currentPage + 1) %}
                            <a href="{{ path('admin_auditoria_index', filtros|merge({page: i})) }}"
                               class="w-8 h-8 flex items-center justify-center rounded-lg text-on-surface-variant hover:bg-surface-container-low font-medium text-sm transition-colors">
                                {{ i }}
                            </a>
                        {% elseif i == 4 or i == totalPages - 3 %}
                            <span class="text-on-surface-variant px-1">...</span>
                        {% endif %}
                    {% endfor %}

                    {% if currentPage < totalPages %}
                        <a href="{{ path('admin_auditoria_index', filtros|merge({page: currentPage + 1})) }}"
                           class="p-2 rounded-full hover:bg-surface-container-low text-on-surface-variant hover:text-primary transition-colors">
                            <span class="material-symbols-outlined text-[20px]">chevron_right</span>
                        </a>
                    {% else %}
                        <button disabled class="p-2 rounded-full text-outline/50 cursor-not-allowed">
                            <span class="material-symbols-outlined text-[20px]">chevron_right</span>
                        </button>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
