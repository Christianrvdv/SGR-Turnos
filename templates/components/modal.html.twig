{# templates/components/modal.html.twig #}
{% set id = id|default('modal-' ~ random()) %}
{% set title = title|default(null) %}
{% set size = size|default('md') %}
{% set closeOnBackdrop = closeOnBackdrop ?? true %}
{% set closeOnEscape = closeOnEscape ?? true %}
{% set showCloseButton = showCloseButton ?? true %}

{% set sizeClasses = {
    'sm': 'max-w-sm',
    'md': 'max-w-md',
    'lg': 'max-w-lg',
    'xl': 'max-w-xl',
    '2xl': 'max-w-2xl',
    'full': 'max-w-[95%]'
} %}

<div id="{{ id }}"
     class="fixed inset-0 bg-on-surface/40 backdrop-blur-sm z-50 flex items-center justify-center p-4 sm:p-6 hidden transition-opacity duration-200"
     data-close-on-backdrop="{{ closeOnBackdrop ? 'true' : 'false' }}"
     data-close-on-escape="{{ closeOnEscape ? 'true' : 'false' }}">
    <div class="bg-surface-container-lowest w-full {{ sizeClasses[size]|default('max-w-2xl') }} rounded-xl sunken-shadow flex flex-col overflow-hidden max-h-[90vh]">
        {% block header %}
            {% if title or showCloseButton %}
                <div class="px-8 py-6 bg-surface flex items-center justify-between">
                    {% if title %}
                        <h2 class="text-xl font-bold text-on-surface tracking-tight">{{ title }}</h2>
                    {% else %}
                        <div></div>
                    {% endif %}
                    {% if showCloseButton %}
                        <button onclick="closeModal('{{ id }}')"
                                class="text-on-surface-variant hover:text-on-surface hover:bg-surface-container p-2 rounded-full transition-colors">
                            <span class="material-symbols-outlined">close</span>
                        </button>
                    {% endif %}
                </div>
            {% endif %}
        {% endblock %}

        <div class="px-8 py-6 overflow-y-auto flex-1">
            {% block body %}{% endblock %}
        </div>

        {% if block('footer') is defined %}
            <div class="px-8 py-5 bg-surface-container-low border-t border-outline-variant/10">
                {% block footer %}{% endblock %}
            </div>
        {% endif %}
    </div>
</div>
