{# templates/ingreso/index.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Ingreso de CI - SGR-Turnos{% endblock %}

{% block body %}
    <main class="flex-grow flex items-center justify-center pt-20 px-4 md:px-8 bg-surface">
        <div class="w-full max-w-4xl grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12">
            {# Lado izquierdo: mensaje #}
            <div class="md:col-span-5 flex flex-col justify-center space-y-6 md:pl-6 pl-0">
                <div class="space-y-4">
                    <h1 class="text-5xl font-extrabold font-headline tracking-tight text-on-surface leading-tight text-left">
                        Ingrese<br/>Carnet de<br/>Identidad
                    </h1>
                    <p class="text-lg text-on-surface-variant max-w-sm text-left">
                        Por favor, introduzca su número de documento para comenzar su turno de atención.
                    </p>
                </div>
                <div
                    class="w-16 h-2 bg-gradient-to-r from-primary to-primary-container rounded-full hidden md:block"></div>
            </div>

            {# Lado derecho: teclado #}
            <div class="md:col-span-7">
                <div
                    class="bg-surface-container-lowest p-8 md:p-12 rounded-[2rem] sunken-shadow border border-surface-container-low relative overflow-hidden flex flex-col gap-8">
                    <div
                        class="absolute -top-24 -right-24 w-64 h-64 bg-primary/5 rounded-full blur-3xl pointer-events-none"></div>

                    {# Formulario #}
                    <form method="post" action="{{ path('app_ingreso_procesar') }}" id="ciForm"
                          class="space-y-8 relative z-10">
                        <div class="space-y-2">
                            <label class="text-sm font-medium text-on-surface-variant block ml-2" for="ci-input">Número
                                de Carnet</label>
                            <div class="relative">
                                <input type="text" name="ci" id="ci-input" readonly
                                       class="w-full h-20 text-4xl text-center font-bold text-primary bg-surface-container-low rounded-xl border-none focus:ring-4 focus:ring-primary/15 transition-shadow placeholder:text-outline-variant/50"
                                       placeholder="Ej. 90123456789">
                                <div class="absolute inset-y-0 right-6 flex items-center pointer-events-none">
                                    <span class="material-symbols-outlined text-outline-variant text-3xl">badge</span>
                                </div>
                            </div>
                        </div>

                        {# Teclado numérico #}
                        <div class="grid grid-cols-3 gap-4">
                            {% for num in 1..9 %}
                                <button type="button" data-digit="{{ num }}"
                                        class="h-20 bg-surface text-3xl font-bold text-on-surface rounded-xl hover:bg-surface-container active:scale-95 transition-all shadow-sm">
                                    {{ num }}
                                </button>
                            {% endfor %}
                            <button type="button" id="btnBorrar"
                                    class="h-20 bg-error-container text-on-error-container text-xl font-semibold rounded-xl hover:bg-error/20 active:scale-95 transition-all flex flex-col items-center justify-center gap-1">
                                <span class="material-symbols-outlined">backspace</span>
                                <span class="text-sm">Borrar</span>
                            </button>
                            <button type="button" data-digit="0"
                                    class="h-20 bg-surface text-3xl font-bold text-on-surface rounded-xl hover:bg-surface-container active:scale-95 transition-all shadow-sm">
                                0
                            </button>
                            <button type="submit"
                                    class="h-20 bg-gradient-to-br from-primary to-primary-container text-on-primary text-xl font-bold rounded-xl hover:opacity-90 active:scale-95 transition-all shadow-[0_12px_32px_-4px_rgba(26,28,29,0.15)] flex flex-col items-center justify-center gap-1">
                                <span class="material-symbols-outlined">arrow_forward</span>
                                <span class="text-sm">Continuar</span>
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </main>

    <script>
        (function () {
            const input = document.getElementById('ci-input');
            const form = document.getElementById('ciForm');

            // Manejar clic en dígitos
            document.querySelectorAll('[data-digit]').forEach(btn => {
                btn.addEventListener('click', () => {
                    input.value += btn.dataset.digit;
                });
            });

            // Borrar último carácter
            document.getElementById('btnBorrar').addEventListener('click', () => {
                input.value = input.value.slice(0, -1);
            });

            // Validar antes de enviar
            form.addEventListener('submit', (e) => {
                if (!input.value.trim()) {
                    e.preventDefault();
                    alert('Debe ingresar un número de carnet');
                }
            });

            // También permitir teclado físico
            input.addEventListener('keydown', (e) => {
                const key = e.key;
                if (/^[0-9]$/.test(key)) {
                    e.preventDefault();
                    input.value += key;
                } else if (key === 'Backspace') {
                    e.preventDefault();
                    input.value = input.value.slice(0, -1);
                } else if (key === 'Enter') {
                    e.preventDefault();
                    if (input.value.trim()) {
                        form.submit();
                    }
                }
            });

            // Enfocar automáticamente para que funcione el teclado físico
            input.focus();
        })();
    </script>
{% endblock %}
